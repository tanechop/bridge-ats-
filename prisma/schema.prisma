generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SEEKER
  RECRUITER
  ADMIN
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String
  password  String
  role      Role     @default(SEEKER)
  phone     String?
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  seekerProfile    SeekerProfile?
  recruiterProfile RecruiterProfile?
}

model SeekerProfile {
  id                Int      @id @default(autoincrement())
  userId            Int      @unique
  user              User     @relation(fields: [userId], references: [id])
  title             String?
  city              String?
  yearsExp          String?
  skills            String[]
  cvUploaded        Boolean  @default(false)
  profileCompletion Int      @default(0)
  avatar            String?
  memberSince       DateTime @default(now())
  
  seeking          String?
  sectorPreference String?
  cityPreference   String?
  availableFrom    String?

  education    Education[]
  experience   Experience[]
  applications Application[]
}

model RecruiterProfile {
  id           Int      @id @default(autoincrement())
  userId       Int      @unique
  user         User     @relation(fields: [userId], references: [id])
  company      String
  industry     String?
  companySize  String?
  website      String?
  hqLocation   String?
  logoUploaded Boolean @default(false)
  memberSince  DateTime @default(now())

  jobs Job[]
}

model Job {
  id               Int      @id @default(autoincrement())
  title            String
  company          String
  location         String
  type             String
  sector           String
  salary           String?
  description      String   @db.Text
  requirements     String[]
  responsibilities String[]
  skills           String[]
  minEducation     String?
  minExperience    String?
  posted           DateTime @default(now())
  deadline         DateTime?
  
  recruiterId Int
  recruiter   RecruiterProfile @relation(fields: [recruiterId], references: [id])
  
  applications Application[]
}

model Application {
  id        Int      @id @default(autoincrement())
  jobId     Int
  job       Job      @relation(fields: [jobId], references: [id])
  seekerId  Int
  seeker    SeekerProfile @relation(fields: [seekerId], references: [id])
  status    String   @default("pending")
  appliedAt DateTime @default(now())
}

model Education {
  id          Int    @id @default(autoincrement())
  seekerId    Int
  seeker      SeekerProfile @relation(fields: [seekerId], references: [id])
  degree      String
  field       String
  institution String
  year        Int
}

model Experience {
  id          Int     @id @default(autoincrement())
  seekerId    Int
  seeker      SeekerProfile @relation(fields: [seekerId], references: [id])
  title       String
  company     String
  duration    String
  description String? @db.Text
}
